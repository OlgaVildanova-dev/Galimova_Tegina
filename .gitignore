# === Python и IDE ===
# Кэшированные файлы Python
__pycache__/
*.py[cod]
*$py.class

# Виртуальные окружения (создаются через venv, virtualenv, conda)
venv/
env/
.venv/

# Файлы настроек IDE (PyCharm, VSCode)
.idea/
.vscode/
*.iml

# === Файлы проекта ===
# Скомпилированные файлы и папки (если используете PyInstaller и др.)
build/
dist/
*.egg-info

# Логи и временные файлы
*.log
*.tmp

# === Файлы данных приложения ===
# Файл с избранными пользователями, так как он хранит пользовательские данные
favorites.json

# === Операционная система и MacOS ===
.DS_Store
Thumbs.db

# === Git ===
# Файл игнорирования игнорируемых (необязательно, но полезно)
!.gitignore
